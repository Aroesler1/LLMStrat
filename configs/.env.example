# =============================================================================
# QuantaAlpha environment configuration template
#
# Usage:
#   1. cp configs/.env.example .env
#   2. Edit paths and API Key below
#   3. ./run.sh "your exploration direction"
# =============================================================================

# =============================================================================
# Paths (core: adjust these for your environment)
# =============================================================================

# Qlib data directory (path after unpacking cn_data.zip; must contain calendars/, features/, instruments)
QLIB_DATA_DIR=<your_qlib_data_path>

# Output root (all results, cache, logs under this directory)
DATA_RESULTS_DIR=<your_results_path>

# =============================================================================
# Qlib
# =============================================================================
QLIB_PROVIDER_URI=<your_qlib_data_path>
CONDA_ENV_NAME=quantaalpha

# =============================================================================
# LLM API
# =============================================================================
OPENAI_API_KEY=<your_api_key>
OPENAI_BASE_URL=<your_base_url>

# Models
REASONING_MODEL=<your_model>
CHAT_MODEL=<your_model>
# Optional (OpenAI GPT-5.x): none | low | medium | high | xhigh
# Use QA_REASONING_EFFORT to avoid conflicts with rdagent's REASONING_EFFORT validation.
# QA_REASONING_EFFORT=xhigh

# =============================================================================
# Trading (paper/live)
# =============================================================================
ALPACA_API_KEY=<your_alpaca_api_key>
ALPACA_SECRET_KEY=<your_alpaca_secret_key>

# Embedding (optional, for RAG)
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_API_KEY=<your_embedding_key>
# EMBEDDING_BASE_URL=<your_embedding_url>

# =============================================================================
# Global (usually no need to change)
# =============================================================================
USE_LOCAL=True
MAX_RETRY=3
RETRY_WAIT_SECONDS=5
# Hard safety guards (recommended to prevent runaway spend)
LLM_MAX_REQUESTS_PER_RUN=120
LLM_MAX_TOTAL_TOKENS_PER_RUN=120000
LLM_MAX_EMPTY_RESPONSES_PER_RUN=2
QA_MAX_CONSECUTIVE_TASK_FAILURES=3
FACTOR_MINING_TIMEOUT=999999
CHAT_MAX_TOKENS=4000
CHAT_TEMPERATURE=0.7
