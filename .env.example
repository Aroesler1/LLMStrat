# CRSP / WRDS research-grade data
# Set CRSP_API_KEY to your WRDS password/token-equivalent used for non-interactive login.
CRSP_USERNAME=your_wrds_username
CRSP_API_KEY=your_wrds_password

# EODHD data vendor
EODHD_API_TOKEN=your_eodhd_token

# OpenAI-compatible LLM proxy
OPENAI_BASE_URL=http://127.0.0.1:8317/v1
OPENAI_API_KEY=your_proxy_key

# Alpaca paper
ALPACA_PAPER_API_KEY=your_alpaca_paper_key
ALPACA_PAPER_API_SECRET=your_alpaca_paper_secret

# Alpaca live
ALPACA_LIVE_API_KEY=your_alpaca_live_key
ALPACA_LIVE_API_SECRET=your_alpaca_live_secret
